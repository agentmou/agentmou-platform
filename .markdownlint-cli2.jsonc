{
  "globs": [
    "README.md",
    "AGENTS.md",
    "apps/**/*.md",
    "catalog/**/*.md",
    "docs/**/*.md",
    "infra/**/*.md",
    "packages/**/*.md",
    "services/**/*.md",
    "skills/**/*.md",
    "templates/**/*.md",
    "workflows/**/*.md",
    ".codex/**/*.mdc",
    ".cursor/rules/**/*.mdc"
  ],
  "ignores": [
    "**/node_modules/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.pnpm-store/**",
    "**/coverage/**",
    "**/dist/**"
  ]
}
