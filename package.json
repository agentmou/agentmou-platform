{
  "name": "agentmou-platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2",
      "brace-expansion": "^5.0.5",
      "micromatch>picomatch": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "smol-toml": "1.6.1"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint && pnpm lint:biome && pnpm lint:infra",
    "lint:biome": "biome check .",
    "typecheck": "turbo run typecheck && pnpm typecheck:agents",
    "test": "turbo run test",
    "audit": "pnpm audit",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "biome format --write .",
    "db:generate": "pnpm --filter @agentmou/db generate",
    "db:migrate": "pnpm --filter @agentmou/db migrate",
    "db:studio": "pnpm --filter @agentmou/db studio",
    "db:seed": "pnpm --filter @agentmou/db seed",
    "cleanup:validation-tenant": "tsx scripts/cleanup-validation-tenant.ts",
    "demo-catalog:generate": "tsx scripts/generate-operational-catalog-ids.ts",
    "demo-catalog:check": "pnpm demo-catalog:generate && git diff --exit-code -- apps/web/lib/demo-catalog/operational-ids.gen.json",
    "lint:compose": "docker compose --env-file infra/compose/.env.example -f infra/compose/docker-compose.local.yml config >/dev/null && docker compose --env-file infra/compose/.env.example -f infra/compose/docker-compose.prod.yml config >/dev/null",
    "lint:infra": "bash -n infra/scripts/*.sh && pnpm lint:compose",
    "test:agents": "python3 -m unittest discover -s services/agents -p 'test_*.py'",
    "typecheck:agents": "python3 -m py_compile services/agents/main.py",
    "setup": "bash infra/scripts/setup.sh",
    "backup": "bash infra/scripts/backup.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@agentmou/db": "workspace:*",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "markdownlint-cli2": "^0.22.0",
    "turbo": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
