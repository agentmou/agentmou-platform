# =============================================================================
# Agentmou Stack — Environment Variables
# =============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git.
# =============================================================================
#
# Canonical production split:
#   https://agentmou.io      -> marketing host
#   https://app.agentmou.io  -> auth + tenant app host
#   https://api.agentmou.io  -> API host
#
# The Docker `web` profile is optional. The primary deployment model keeps the
# marketing/app frontend outside this VPS stack.

# --- Domain ------------------------------------------------------------------
DOMAIN=agentmou.io

# --- Let's Encrypt -----------------------------------------------------------
LE_EMAIL=admin@agentmou.io

# --- Traefik BasicAuth -------------------------------------------------------
# Generate with: htpasswd -nB admin
# Escape dollar signs by doubling them ($$) for Docker Compose.
BASIC_AUTH_USERS=admin:$$apr1$$CHANGEME

# --- PostgreSQL --------------------------------------------------------------
# Avoid / @ : # in password (breaks DATABASE_URL parsing).
# Generate: openssl rand -hex 24
POSTGRES_DB=agentmou
POSTGRES_USER=agentmou
POSTGRES_PASSWORD=changeme

# --- n8n ---------------------------------------------------------------------
TZ=Europe/Madrid
N8N_EDITOR_BASE_URL=https://n8n.agentmou.io
WEBHOOK_URL=https://hooks.agentmou.io
N8N_PROXY_HOPS=1
N8N_ENCRYPTION_KEY=changeme-generate-a-random-string

# --- Agents (Python) --------------------------------------------------------
AGENTS_API_KEY=changeme
OPENAI_API_KEY=sk-changeme

# --- Control Plane API + Worker ---------------------------------------------
# These are used by services/api and services/worker (always active).
JWT_SECRET=changeme
# Browser origin allowed to call the API from the tenant app.
CORS_ORIGIN=https://app.agentmou.io

# --- B2C OAuth (Google / Microsoft) — services/api -----------------------------
# Comma-separated public web origins allowed for ?return_url=... on /auth/callback.
# Keep this aligned with your Vercel/custom-domain frontend origins.
AUTH_WEB_ORIGIN_ALLOWLIST=https://app.agentmou.io
# Public URL of the API as registered with Google/Microsoft (must match console redirect URIs).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.agentmou.io/api/v1/auth/oauth/google/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://api.agentmou.io/api/v1/auth/oauth/microsoft/callback
# Direct transactional auth email delivery via Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@agentmou.io
# Canonical public origins.
MARKETING_PUBLIC_BASE_URL=https://agentmou.io
APP_PUBLIC_BASE_URL=https://app.agentmou.io
API_PUBLIC_BASE_URL=https://api.agentmou.io
# Set to 1 only if you explicitly want reset links in API logs.
LOG_PASSWORD_RESET_LINK=0

# --- n8n API (used by n8n-client for workflow provisioning) -----------------
N8N_API_URL=http://n8n:5678/api/v1
N8N_API_KEY=changeme

# --- Google OAuth (Gmail connector) -----------------------------------------
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URI=https://api.agentmou.io/api/v1/oauth/callback

# --- Connector encryption ---------------------------------------------------
# 32-byte key for AES-256-GCM encryption of OAuth tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONNECTOR_ENCRYPTION_KEY=changeme-generate-64-hex-chars

# --- Twilio clinic channels -------------------------------------------------
# Shared Twilio account credentials used by clinic WhatsApp and voice adapters.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional defaults for outbound channel senders. Per-channel config can override them.
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_MESSAGING_SERVICE_SID=
TWILIO_VOICE_FROM=

# --- Retell AI voice --------------------------------------------------------
# Fallback credentials when tenant-specific secrets are not provisioned.
RETELL_API_KEY=
RETELL_AGENT_ID_DEFAULT=
RETELL_WEBHOOK_SECRET=

# --- Reflag feature flags ---------------------------------------------------
# Two keys, two audiences:
#
#   REFLAG_SDK_KEY               (SERVER, secret) — authoritative evaluation
#                                 inside services/api. Used for both `rollout.*`
#                                 and `plan.*` namespaces. Never expose.
#
#   NEXT_PUBLIC_REFLAG_PUBLISHABLE_KEY  (CLIENT, public) — optional. Only
#                                 powers non-authorization UI hints in the
#                                 browser (e.g. A/B copy, banner ordering).
#                                 Authorization decisions always come from the
#                                 server-resolved TenantExperience payload.
REFLAG_SDK_KEY=
REFLAG_ENVIRONMENT=development
# Optional when pointing the SDK at a non-default Reflag base URL.
REFLAG_BASE_URL=
# Optional JSON overrides for local/dev/test. Examples:
# {"clinic.reactivation.enabled":false}
# {"defaults":{"admin.console.enabled":false},"tenants":{"demo-workspace":{"clinic.forms.enabled":false}}}
REFLAG_LOCAL_OVERRIDES_JSON=

# Client-side Reflag — leave empty unless the web app needs it.
NEXT_PUBLIC_REFLAG_PUBLISHABLE_KEY=
NEXT_PUBLIC_REFLAG_ENVIRONMENT=development

# --- Web marketing lead capture --------------------------------------------
CONTACT_SALES_WEBHOOK_URL=
CONTACT_SALES_WEBHOOK_TOKEN=

# --- Legacy / historical keys retained from VPS history ---------------------
# These keys are preserved so repo templates, the live VPS .env, and older
# backups can be reconciled without dropping historical configuration.
# Current deployments should prefer the split-origin contract above.

# Legacy pre-split web app origin used before APP_PUBLIC_BASE_URL existed.
WEB_APP_BASE_URL=http://localhost:3000

# Historical internal ops runtime retained from older VPS snapshots/templates.
INTERNAL_OPS_TENANT_ID=00000000-0000-0000-0000-000000000000
INTERNAL_OPS_TELEGRAM_BOT_TOKEN=changeme
INTERNAL_OPS_TELEGRAM_WEBHOOK_SECRET=changeme
INTERNAL_OPS_CALLBACK_SECRET=changeme
INTERNAL_OPS_TELEGRAM_ALLOWED_CHAT_IDS=
INTERNAL_OPS_TELEGRAM_ALLOWED_USER_IDS=
OPENCLAW_API_URL=https://openclaw.example.com
OPENCLAW_API_KEY=changeme
OPENCLAW_TIMEOUT_MS=15000
