# Database
DB_USER=agentmou
DB_PASSWORD=changeme
DB_NAME=agentmou
DB_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# API Configuration
API_HOST=api.agentmou.local
API_PORT=3001

# Web Configuration
WEB_HOST=app.agentmou.local
WEB_PORT=3000

# n8n Configuration
N8N_HOST=n8n.agentmou.local
N8N_USER=admin
N8N_PASSWORD=changeme

# Timezone
TZ=UTC

# Composed URLs (used by API/worker services)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}
REDIS_URL=redis://localhost:${REDIS_PORT}

# Auth
JWT_SECRET=change-me-in-production

# Node Environment
NODE_ENV=local
