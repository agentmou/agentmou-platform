# =============================================================================
# AgentMou OpenClaw Runtime — Environment Variables
# =============================================================================
# Copy to .env.openclaw and fill in real values:
#   cp .env.openclaw.example .env.openclaw
#
# NEVER commit .env.openclaw to git.
# =============================================================================

DOMAIN=agentmou.io
LE_EMAIL=admin@agentmou.io

# Bearer token expected from services/internal-ops.
# Must exactly match OPENCLAW_API_KEY on the main AgentMou VPS.
# Generate with: openssl rand -hex 32
OPENCLAW_API_KEY=changeme

# Model-backed planning.
OPENAI_API_KEY=sk-changeme
OPENCLAW_MODEL=gpt-4o-mini

# Runtime state persistence directory inside the container.
OPENCLAW_STATE_DIR=/data/state
