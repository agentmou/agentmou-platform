# Agentmou offsite backup target
RESTIC_REPOSITORY=s3:s3.eu-central-003.backblazeb2.com/agentmou-backups/vps-n8n-agents
RESTIC_PASSWORD_FILE=/etc/agentmou/restic-password

# S3-compatible credentials
AWS_ACCESS_KEY_ID=changeme-access-key
AWS_SECRET_ACCESS_KEY=changeme-secret-key
AWS_DEFAULT_REGION=eu-central-003

# Optional local tuning
RESTIC_HOST=vps-n8n-agents
RESTIC_CACHE_DIR=/var/cache/restic
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=6
