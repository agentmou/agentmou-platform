{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "infra/compose/.env.example", ".github/workflows/ci.yml"],
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "REDIS_URL", "NEXT_PUBLIC_API_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
