{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env",
    "infra/compose/.env.example",
    ".github/workflows/ci.yml",
    "eslint.config.js",
    "tsconfig.base.json"
  ],
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "REDIS_URL", "NEXT_PUBLIC_API_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "MARKETING_PUBLIC_BASE_URL",
        "APP_PUBLIC_BASE_URL",
        "API_PUBLIC_BASE_URL"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
